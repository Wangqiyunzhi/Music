<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rabbiter.music.dao.BannerMapper">

    <resultMap id="BaseResultMap" type="com.rabbiter.music.pojo.Banner">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="pic" property="pic"/>
        <result column="link" property="link"/>
        <result column="sort" property="sort"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, title, pic, link, sort, status, create_time, update_time
    </sql>

    <insert id="insert" parameterType="com.rabbiter.music.pojo.Banner" useGeneratedKeys="true" keyProperty="id">
        insert into banner (title, pic, link, sort, status)
        values (#{title}, #{pic}, #{link}, #{sort}, #{status})
    </insert>

    <update id="update" parameterType="com.rabbiter.music.pojo.Banner">
        update banner
        <set>
            <if test="title != null">title = #{title},</if>
            <if test="pic != null">pic = #{pic},</if>
            <if test="link != null">link = #{link},</if>
            <if test="sort != null">sort = #{sort},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        where id = #{id}
    </update>

    <delete id="delete" parameterType="java.lang.Integer">
        delete from banner where id = #{id}
    </delete>

    <select id="selectByPrimaryKey" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from banner
        where id = #{id}
    </select>

    <select id="allBanner" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from banner
        order by sort asc, id desc
    </select>

    <select id="bannerOfStatus" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from banner
        where status = #{status}
        order by sort asc, id desc
    </select>

    <select id="bannerForHome" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/> from banner
        where status = 1
        order by sort asc, id desc
    </select>

</mapper>
